
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font-sans); }
#app { padding: 1rem 0; }
.header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
.header h1 { font-size: 18px; font-weight: 500; color: var(--color-text-primary); }
.status-badge { display: flex; align-items: center; gap: 6px; font-size: 13px; padding: 4px 12px; border-radius: 20px; border: 0.5px solid var(--color-border-tertiary); }
.dot { width: 8px; height: 8px; border-radius: 50%; }
.dot.connected { background: #63B84A; }
.dot.disconnected { background: #E24B4A; }
.dot.waiting { background: #EF9F27; animation: pulse 1.2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

.alert-box { border-radius: var(--border-radius-lg); border: 0.5px solid var(--color-border-tertiary); padding: 1.25rem; margin-bottom: 1.5rem; background: var(--color-background-primary); }
.alert-box.crisis { border-color: #E24B4A; background: #FCEBEB; animation: flashBorder 0.5s 4; }
@keyframes flashBorder { 0%,100%{border-color:#E24B4A} 50%{border-color:#F09595} }
.alert-icon { font-size: 40px; text-align: center; margin-bottom: 8px; }
.alert-title { font-size: 16px; font-weight: 500; text-align: center; color: var(--color-text-primary); }
.alert-title.crisis-text { color: #A32D2D; }
.alert-sub { font-size: 13px; text-align: center; color: var(--color-text-secondary); margin-top: 4px; }
.alert-sub.crisis-text { color: #993C1D; }

.stats-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 1.5rem; }
.stat-card { background: var(--color-background-secondary); border-radius: var(--border-radius-md); padding: 1rem; text-align: center; }
.stat-label { font-size: 13px; color: var(--color-text-secondary); margin-bottom: 4px; }
.stat-value { font-size: 24px; font-weight: 500; color: var(--color-text-primary); }
.stat-value.red { color: #A32D2D; }

.section-title { font-size: 14px; font-weight: 500; color: var(--color-text-secondary); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em; }
.history-list { border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); overflow: hidden; margin-bottom: 1.5rem; }
.history-item { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-bottom: 0.5px solid var(--color-border-tertiary); background: var(--color-background-primary); }
.history-item:last-child { border-bottom: none; }
.history-item.empty { justify-content: center; color: var(--color-text-tertiary); font-size: 14px; padding: 1.5rem; }
.h-left { display: flex; align-items: center; gap: 10px; }
.h-dot { width: 8px; height: 8px; border-radius: 50%; background: #E24B4A; flex-shrink: 0; }
.h-text { font-size: 14px; color: var(--color-text-primary); }
.h-time { font-size: 12px; color: var(--color-text-secondary); }
.h-dur { font-size: 12px; color: var(--color-text-secondary); background: var(--color-background-secondary); padding: 2px 8px; border-radius: 10px; }

.config-box { border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1rem 1.25rem; background: var(--color-background-primary); margin-bottom: 1.5rem; }
.config-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.config-row:last-child { margin-bottom: 0; }
.config-label { font-size: 13px; color: var(--color-text-secondary); min-width: 80px; }
.config-row input { flex: 1; font-size: 13px; padding: 6px 10px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); background: var(--color-background-secondary); color: var(--color-text-primary); }
.btn-row { display: flex; gap: 8px; margin-top: 10px; }
button { cursor: pointer; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); background: transparent; color: var(--color-text-primary); font-size: 13px; padding: 7px 16px; }
button:hover { background: var(--color-background-secondary); }
button.primary { background: var(--color-text-primary); color: var(--color-background-primary); border-color: var(--color-text-primary); }
button.primary:hover { opacity: 0.85; }
button.danger { border-color: #E24B4A; color: #A32D2D; }
button.danger:hover { background: #FCEBEB; }

.alert-box.esp-conectada { border-color: #639922; background: #EAF3DE; }
.alert-title.conectada-text { color: #27500A; }
.alert-sub.conectada-text { color: #3B6D11; }
.simulate-btn { width: 100%; padding: 12px; font-size: 14px; font-weight: 500; margin-bottom: 1rem; border-color: #E24B4A; color: #A32D2D; }
.simulate-btn:hover { background: #FCEBEB; }
</style>

<div id="app">
  <div class="header">
    <h1>Monitor de crisis epilépticas</h1>
    <div class="status-badge" id="status-badge">
      <div class="dot waiting" id="status-dot"></div>
      <span id="status-text">Conectando...</span>
    </div>
  </div>

  <div class="alert-box" id="alert-box">
    <div class="alert-icon" id="alert-icon">⏳</div>
    <div class="alert-title" id="alert-title">Esperando ESP32...</div>
    <div class="alert-sub" id="alert-sub">La ESP32 aún no se conectó</div>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-label">Hoy</div>
      <div class="stat-value red" id="stat-today">0</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Esta semana</div>
      <div class="stat-value" id="stat-week">0</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total</div>
      <div class="stat-value" id="stat-total">0</div>
    </div>
  </div>

  <button class="simulate-btn" id="sim-btn">Simular alerta (demo)</button>

  <div class="section-title">Historial de eventos</div>
  <div class="history-list" id="history-list">
    <div class="history-item empty" id="empty-msg">Sin eventos registrados</div>
  </div>

  <div class="section-title">Configuración MQTT</div>
  <div class="config-box">
    <div class="config-row">
      <span class="config-label">Broker</span>
      <input id="cfg-broker" value="broker.hivemq.com" />
    </div>
    <div class="config-row">
      <span class="config-label">Puerto</span>
      <input id="cfg-port" value="8884" style="max-width:100px" />
    </div>
    <div class="config-row">
      <span class="config-label">Topic</span>
      <input id="cfg-topic" value="epilepsia/alerta" />
    </div>
    <div class="btn-row">
      <button class="primary" id="btn-connect">Conectar</button>
      <button id="btn-disconnect">Desconectar</button>
      <button class="danger" id="btn-clear">Limpiar historial</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/mqtt/4.3.7/mqtt.min.js"></script>
<script>
let client = null;
let connected = false;
let events = [];
let todayCount = 0;
let weekCount = 0;
let alertTimeout = null;

function setStatus(state, text) {
  const dot = document.getElementById('status-dot');
  const badge = document.getElementById('status-badge');
  const statusText = document.getElementById('status-text');
  dot.className = 'dot ' + state;
  statusText.textContent = text;
}

function triggerAlert(data) {
  const box = document.getElementById('alert-box');
  const icon = document.getElementById('alert-icon');
  const title = document.getElementById('alert-title');
  const sub = document.getElementById('alert-sub');

  box.className = 'alert-box crisis';
  icon.textContent = '🔴';
  title.className = 'alert-title crisis-text';
  title.textContent = '¡CRISIS DETECTADA!';
  sub.className = 'alert-sub crisis-text';
  sub.textContent = data.timestamp ? 'Evento recibido: ' + data.timestamp : 'Evento recibido ahora';

  try { new Audio("data:audio/wav;base64,UklGRl9vT19XQVZFZm10IBAAAA...").play(); } catch(e) {}

  if (alertTimeout) clearTimeout(alertTimeout);
  alertTimeout = setTimeout(() => {
    box.className = 'alert-box';
    icon.textContent = '🟢';
    title.className = 'alert-title';
    title.textContent = 'Paciente estable';
    sub.className = 'alert-sub';
    sub.textContent = 'Último evento hace ' + getRelativeTime(data.time);
  }, 8000);

  addToHistory(data);
}

function getRelativeTime(t) {
  const diff = Math.floor((Date.now() - t) / 1000);
  if (diff < 60) return diff + 's';
  return Math.floor(diff/60) + 'min';
}

function addToHistory(data) {
  const now = new Date(data.time || Date.now());
  const entry = {
    time: now,
    label: 'Crisis detectada',
    duration: data.duration || null
  };
  events.unshift(entry);
  todayCount++;
  weekCount++;
  updateStats();
  renderHistory();
}

function updateStats() {
  document.getElementById('stat-today').textContent = todayCount;
  document.getElementById('stat-week').textContent = weekCount;
  document.getElementById('stat-total').textContent = events.length;
}

function renderHistory() {
  const list = document.getElementById('history-list');
  if (events.length === 0) {
    list.innerHTML = '<div class="history-item empty" id="empty-msg">Sin eventos registrados</div>';
    return;
  }
  list.innerHTML = events.slice(0, 10).map(e => {
    const t = e.time;
    const timeStr = t.toLocaleTimeString('es-AR', {hour:'2-digit', minute:'2-digit'}) + 
                    ' - ' + t.toLocaleDateString('es-AR', {day:'2-digit', month:'short'});
    return `<div class="history-item">
      <div class="h-left">
        <div class="h-dot"></div>
        <div>
          <div class="h-text">${e.label}</div>
          <div class="h-time">${timeStr}</div>
        </div>
      </div>
      ${e.duration ? `<div class="h-dur">${e.duration}s</div>` : ''}
    </div>`;
  }).join('');
}

function connect() {
  const broker = document.getElementById('cfg-broker').value;
  const port = parseInt(document.getElementById('cfg-port').value);
  const topic = document.getElementById('cfg-topic').value;

  setStatus('waiting', 'Conectando...');

  try {
    const url = `wss://${broker}:${port}/mqtt`;
    client = mqtt.connect(url, { clientId: 'epilepsia_monitor_' + Math.random().toString(16).substr(2,8), reconnectPeriod: 3000 });

    client.on('connect', () => {
      connected = true;
      setStatus('connected', 'Conectado — ' + topic);
      client.subscribe(topic);
    });

    client.on('message', (t, msg) => {
      const raw = msg.toString();

      if (raw === 'esp32_conectada') {
        const box = document.getElementById('alert-box');
        const icon = document.getElementById('alert-icon');
        const title = document.getElementById('alert-title');
        const sub = document.getElementById('alert-sub');
        box.className = 'alert-box esp-conectada';
        icon.textContent = '✅';
        title.className = 'alert-title conectada-text';
        title.textContent = 'ESP32 encendida y conectada';
        sub.className = 'alert-sub conectada-text';
        sub.textContent = 'Conectada a las ' + new Date().toLocaleTimeString('es-AR', {hour:'2-digit', minute:'2-digit', second:'2-digit'});
        return;
      }

      if (raw === 'alerta') {
        let data = { time: Date.now() };
        triggerAlert(data);
        return;
      }
    });

    client.on('error', () => setStatus('disconnected', 'Error de conexión'));
    client.on('offline', () => setStatus('disconnected', 'Sin conexión'));
    client.on('reconnect', () => setStatus('waiting', 'Reconectando...'));
  } catch(e) {
    setStatus('disconnected', 'Error');
  }
}

document.getElementById('btn-connect').addEventListener('click', connect);

document.getElementById('btn-disconnect').addEventListener('click', () => {
  if (client) { client.end(); client = null; connected = false; }
  setStatus('disconnected', 'Desconectado');
});

document.getElementById('btn-clear').addEventListener('click', () => {
  events = []; todayCount = 0; weekCount = 0;
  updateStats(); renderHistory();
  const box = document.getElementById('alert-box');
  box.className = 'alert-box';
  document.getElementById('alert-icon').textContent = '⏳';
  document.getElementById('alert-title').className = 'alert-title';
  document.getElementById('alert-title').textContent = 'Esperando ESP32...';
  document.getElementById('alert-sub').className = 'alert-sub';
  document.getElementById('alert-sub').textContent = 'La ESP32 aún no se conectó';
});

document.getElementById('sim-btn').addEventListener('click', () => {
  triggerAlert({ time: Date.now(), duration: Math.floor(Math.random()*20)+5 });
});

setTimeout(connect, 500);
</script>
